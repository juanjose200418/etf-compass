DB_NAME=etf_compass
DB_URL=jdbc:postgresql://localhost:5433/etf_compass
DB_USERNAME=etf_compass
DB_PASSWORD=etf_compass
JWT_SECRET=replace-with-a-strong-32-character-secret
SPRING_PROFILES_ACTIVE=prod
MARKET_DATA_PROVIDER=finnhub
FINNHUB_API_KEY=
FMP_API_KEY=
MARKET_DATA_ENRICH_ON_POSITION_CREATE=true
CORS_ALLOWED_ORIGINS=http://localhost:4200,https://TU-FRONTEND.vercel.app
SPRINGDOC_API_DOCS_ENABLED=true
SPRINGDOC_SWAGGER_UI_ENABLED=true

# ── Password reset delivery mode ──────────────────
# logging = show code in server logs (default, no email sent)
# smtp    = send code via SMTP email (requires SMTP_* vars)
PASSWORD_RESET_DELIVERY=logging

# ── SMTP / Email (Google Gmail) ────────────────────
# 1. Activa 2FA en tu cuenta Google: https://myaccount.google.com/security
# 2. Crea una App Password: https://myaccount.google.com/apppasswords
# 3. Usa esa App Password como SMTP_PASSWORD (sin espacios)
# 4. SMTP_HOST y SMTP_PORT no se tocan para Gmail
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=TU_EMAIL@gmail.com
SMTP_PASSWORD=tu-app-password-de-16-letras
SMTP_FROM=TU_EMAIL@gmail.com
SMTP_SMTP_AUTH=true
SMTP_SMTP_STARTTLS=true
SMTP_SMTP_SSL=false
